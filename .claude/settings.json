{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "AI エージェント設定テンプレート。HITL を PR マージ承認に集約する設計（HUMAN_IN_THE_LOOP.md §2 参照）。プロジェクトに応じて allow を絞る、deny を増やすなど調整してよい。",

  "permissions": {
    "_comment_allow": "AI エージェントが自律的に進めてよい操作。PR を作るまでは止めずに完走させる方針。",
    "allow": [
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm ci)",
      "Bash(npm uninstall:*)",
      "Bash(npm run *)",
      "Bash(npm run:*)",
      "Bash(npx *)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git checkout -b feature/*)",
      "Bash(git checkout feature/*)",
      "Bash(git checkout develop)",
      "Bash(git checkout main)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git commit -m:*)",
      "Bash(git push origin feature/*)",
      "Bash(git push origin develop)",
      "Bash(git push origin main)",
      "Bash(git push -u origin *)",
      "Bash(git fetch *)",
      "Bash(git pull origin *)",
      "Bash(git merge develop)",
      "Bash(git merge main)",
      "Bash(gh repo view*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr create*)",
      "Bash(gh pr comment*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr ready*)",
      "Bash(gh api *)",
      "Bash(gh workflow view*)",
      "Bash(gh workflow run*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh run watch*)",
      "Bash(mkdir -p *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(**)",
      "Write(**)"
    ],

    "_comment_ask": "人間の判断ゲート。PR マージ承認のみに絞る。",
    "ask": [
      "Bash(gh pr merge*)",
      "Bash(gh pr review*--approve*)",
      "Bash(gh pr review * --approve*)"
    ],

    "_comment_deny": "技術的に止めるべき破壊的操作。HUMAN_IN_THE_LOOP.md §例外参照。",
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push origin :*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(gh repo delete*)",
      "Bash(gh release delete*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Read(.env*)"
    ]
  }
}
